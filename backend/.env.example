# ── MongoDB ──────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/aicodementor

# ── Groq API Keys ─────────────────────────────────────────────
# Main key for code review (ai.services.js)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Key for quiz generation (ai.js / routes/ai.js)
GROQ_QUIZ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Key for learning challenges (groq.routes.js)
GROQ_API_KEY_LEARNING=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# NOTE: You can use the same Groq key for all three above.

# ── Session ───────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=replace_with_a_long_random_string_at_least_64_chars

# ── CORS ─────────────────────────────────────────────────────
FRONTEND_URL=https://ai-code-mentor.vercel.app

# ── Server ───────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Cookie Domain (leave blank unless using custom domain) ────
# COOKIE_DOMAIN=
